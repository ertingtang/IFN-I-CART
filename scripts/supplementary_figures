##====================================-- Fig S2B, DEG, validation cohort --===============================================##
px <- ggplot(DEGs.CRvsNR, aes(x=avg_log2FC_v2, y=negLogPval)) +
  geom_point(size=2, color=alpha("grey", 0.5)) + # Plots all points with some transparency +
  geom_point(data=DEGs.CRvsNR[DEGs.CRvsNR$X%in%ISGs,], aes(x=avg_log2FC_v2, y=negLogPval),
             size=2.5, color="#E64B35B2") + 
  geom_text_repel(data=DEGs.CRvsNR[DEGs.CRvsNR$X%in%ISGs & DEGs.CRvsNR$p_val_adj<0.05 & DEGs.CRvsNR$avg_log2FC>0.25,], 
                  aes(x = avg_log2FC_v2, y = negLogPval, label = X),
                  size = 3.5, color="black", 
                  segment.color = "black", 
                  segment.size = 0.25,
                  max.overlaps = 10000,
                  min.segment.length=0) + # label genes
  labs(x="Log2 Fold Change", y="-Log10 Adjusted P-Value", title="CR vs NR") + # Threshold lines for logFC
  theme_pubr() + # decide theme
  theme(
    plot.title = element_text(size=20, face = "bold", hjust = 0.5),
    axis.title = element_text(size = 15), # Adjust the size of axis titles
    axis.text = element_text(size = 12), # Adjust the size of axis tick text
    legend.title = element_text(size = 15), # Adjust the size of legend title
    legend.text = element_text(size = 15), # Adjust the size of legend text
  ) +
  xlim(-1, 1) +
  geom_hline(yintercept=-log10(0.05), linetype="dashed", color="grey50") + # Threshold line for p-value
  geom_vline(xintercept=c(-0.25, 0.25), linetype="dashed", color="grey50") # Threshold lines for logFC
saveFig(px, "./Other_Data/plots/Maus2022/DEGs/Volcano_plots_ISG.all.highlighted_8pts_All_v2", wd = 2000, ht = 2000)

##====================================-- Fig S2C, gsea, validation cohort --===============================================##
gse.hallmark <- readRDS("./Other_Data/rds/Maus2022_axicel_clean_GSEA.hallmark_CRvsPD.rds")
if ("HALLMARK_INTERFERON_ALPHA_RESPONSE" %in% gse.hallmark@result$ID){
  ## do some annotation
  NES <- sprintf("%.2f", round(gse.hallmark@result[gse.hallmark@result$ID=="HALLMARK_INTERFERON_ALPHA_RESPONSE", "NES"], 2))
  pvalue <- sprintf("%.3f", round(gse.hallmark@result[gse.hallmark@result$ID=="HALLMARK_INTERFERON_ALPHA_RESPONSE", "p.adjust"], 3))
  qvalue <- sprintf("%.3f", round(gse.hallmark@result[gse.hallmark@result$ID=="HALLMARK_INTERFERON_ALPHA_RESPONSE", "qvalue"], 3))
  anno <- paste0("NES = ", NES, "\nFDR q-value = ", qvalue, "\np.adjust = ", pvalue)
  ## plotting
  px <- gseaplot2(gse.hallmark,
                  "HALLMARK_INTERFERON_ALPHA_RESPONSE",
                  title = "HALLMARK: interferon alpha response",
                  subplots = 1:2)
  ## adjust formatting and add annottation
  px[[1]] <- px[[1]] + 
    theme(
      plot.title = element_text(size=25, face = "bold", hjust = 0.5),
      axis.title = element_text(size = 15), 
      axis.text = element_text(size = 15),
    ) + 
    annotate("text",
             label=anno,
             x=Inf, y=Inf-2,
             color="black", hjust=1, vjust=1, size=5)
  px[[2]] <- px[[2]] + 
    labs(x="Rank in Ordered Dataset") +
    theme(
      axis.title = element_text(size = 15), 
      axis.text.x = element_text(size = 15),
    )
  # Combine the plots with custom heights
  px.combine <- px[[1]] / px[[2]]
  # Adjust the plot layout with specific heights
  px.combine <- px.combine +
    plot_layout(guides = 'collect') +  
    plot_layout(heights = c(3, 1))
  saveFig(px.combine, "./Other_Data/plots/Maus2022/GSEA/Clean/AXICEL_1.MO_GSEA_CRvsNR_HALLMARK_interferon_alpha_response", wd = 2500, ht = 2000)
}
